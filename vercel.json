{
  "version": 2,
  "buildCommand": "true",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2",
      "maxDuration": 30
    }
  },
  "env": {
    "APP_NAME": "BanHang",
    "APP_ENV": "production",
    "APP_KEY": "base64:your_app_key_here",
    "APP_DEBUG": "false",
    "APP_URL": "https://banhang.vnsang.io.vn",
    "DB_CONNECTION": "pgsql",
    "DB_HOST": "your_db_host",
    "DB_PORT": "5432",
    "DB_DATABASE": "postgres",
    "DB_USERNAME": "your_db_username",
    "DB_PASSWORD": "your_db_password",
    "CACHE_DRIVER": "array",
    "CACHE_PATH": "/tmp/storage/framework/cache",
    "SESSION_DRIVER": "cookie",
    "SESSION_LIFETIME": "120",
    "QUEUE_CONNECTION": "sync",
    "FILESYSTEM_DISK": "local",
    "FILESYSTEM_VISIBILITY": "private",
    "LOG_CHANNEL": "stderr",
    "LOG_LEVEL": "error",
    "LOG_STACK": "single",
    "MAIL_MAILER": "log",
    "MAIL_FROM_ADDRESS": "noreply@banhang.vnsang.io.vn",
    "MAIL_FROM_NAME": "BanHang",
    "BROADCAST_DRIVER": "log",
    "NEXT_PUBLIC_SUPABASE_URL": "https://your-project.supabase.co",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY": "your_publishable_key",
    "CLOUDINARY_URL": "cloudinary://your_key:your_secret@your_cloud_name",
    "CLOUDINARY_CLOUD_NAME": "your_cloud_name",
    "CLOUDINARY_API_KEY": "your_api_key",
    "CLOUDINARY_API_SECRET": "your_api_secret",
    "VIETQR_ACCOUNT_NO": "your_account_no",
    "VIETQR_ACCOUNT_NAME": "Your Account Name",
    "VIETQR_BIN": "970436",
    "VIETQR_TEMPLATE": "compact2",
    "VIEW_COMPILED_PATH": "/tmp/storage/framework/views",
    "STORAGE_COMPILED_PATH": "/tmp/storage",
    "SANCTUM_STATEFUL_DOMAINS": "banhang.vnsang.io.vn,ban-hang-9eoaw9jvr-vnsang.vercel.app",
    "TRUSTED_PROXIES": "*",
    "CORS_ALLOWED_ORIGINS": "https://banhang.vnsang.io.vn",
    "SESSION_SECURE_COOKIES": "true",
    "SESSION_SAME_SITE": "lax",
    "SESSION_HTTP_ONLY": "true"
  },
  "routes": [
    {
      "src": "^/css/(.*)",
      "dest": "/public/css/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/js/(.*)",
      "dest": "/public/js/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/build/(.*)",
      "dest": "/public/build/$1",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/images/(.*)",
      "dest": "/public/images/$1"
    },
    {
      "src": "^/fonts/(.*)",
      "dest": "/public/fonts/$1"
    },
    {
      "src": "^/storage/(.*)",
      "dest": "/public/storage/$1"
    },
    {
      "src": "^/favicon.ico$",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "^/robots.txt$",
      "dest": "/public/robots.txt"
    },
    {
      "src": "^/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
