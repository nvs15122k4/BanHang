APP_NAME=BanHang
APP_ENV=local
APP_KEY=base64:your_app_key_here
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_PORT=8080

DB_CONNECTION=pgsql
DB_HOST=your_db_host
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

VITE_PORT=5173
VITE_DEV_SERVER_URL=http://localhost:5173

# Cloudinary
CLOUDINARY_URL=cloudinary://your_key:your_secret@your_cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# VietQR
VIETQR_CLIENT_ID=
VIETQR_API_KEY=
VIETQR_ACCOUNT_NO=your_account_no
VIETQR_ACCOUNT_NAME="Your Account Name"
VIETQR_BIN=970436
VIETQR_TEMPLATE=compact2

# Playwright Test Config
PLAYWRIGHT_BASE_URL=http://127.0.0.1:8000
PLAYWRIGHT_ADMIN_URL=http://127.0.0.1:8000/admin/dashboard
PLAYWRIGHT_USER_EMAIL=user@example.com
PLAYWRIGHT_USER_PASSWORD=password
PLAYWRIGHT_ADMIN_EMAIL=admin@example.com
PLAYWRIGHT_ADMIN_PASSWORD=password

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
